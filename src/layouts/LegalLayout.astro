---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
}

const { title, description, canonicalPath } = Astro.props;
---

<BaseLayout
  title={`${title} | Kai Wu`}
  description={description}
  canonicalPath={canonicalPath}
  bodyClass="legal-page"
>
  <main>
    <article class="active legal-article">
      <header>
        <h1 class="h2 article-title">{title}</h1>
      </header>
      <slot />
      <a href="/" class="legal-back-link">Back to homepage</a>
    </article>
  </main>
</BaseLayout>
